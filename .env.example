# ─────────────────────────── 数据库 (Supabase) ───────────────────────────
# 格式: jdbc:postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=jdbc:postgresql://localhost:5432/interview
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password

# ─────────────────────────── Redis (Upstash) ───────────────────────────
# 格式: rediss://default:[PASSWORD]@[host].upstash.io:6379
REDIS_URL=redis://localhost:6379
REDIS_SSL=false

# ─────────────────────────── AI 模型 ───────────────────────────
# 方案一：Agnes AI（默认，国内访问较好）
AI_API_KEY=your_agnes_api_key
AI_BASE_URL=https://apihub.agnes-ai.com
AI_CHAT_MODEL=agnes-2.0-flash
AI_EMBEDDING_MODEL=text-embedding-3-small

# 方案二：TackleKey（OpenAI 兼容，免费额度有限）
# AI_API_KEY=sk-xxxxxxxxxxxx
# AI_BASE_URL=https://api.tacklekey.com
# AI_CHAT_MODEL=openai/gpt-5.5:free
# AI_EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────── JWT ───────────────────────────
# 生产环境必须修改为随机32位以上字符串
JWT_SECRET=change-this-in-production-must-be-32-chars-min!!
JWT_EXPIRATION_MS=86400000

# ─────────────────────────── Supabase Storage ───────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# 在 Supabase Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_BUCKET=resumes

# ─────────────────────────── 前端 (Vercel) ───────────────────────────
VITE_API_BASE_URL=https://your-backend.onrender.com
